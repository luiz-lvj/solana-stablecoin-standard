# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=http://127.0.0.1:8899
SOLANA_MINT_ADDRESS=
TOKEN_PROGRAM=spl-token-2022

# Authority keypair – provide ONE of:
#   SOLANA_KEYPAIR_PATH  – path to a Solana keypair JSON file
#   SOLANA_KEYPAIR_BASE64 – base64-encoded secret key (for containers)
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json
# SOLANA_KEYPAIR_BASE64=

# ── SSS-2 / Compliance (optional) ────────────────────────────────────────────
TRANSFER_HOOK_PROGRAM_ID=
BLACKLIST_ADMIN_KEYPAIR_PATH=
# BLACKLIST_ADMIN_KEYPAIR_BASE64=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info

# ── Event listener ────────────────────────────────────────────────────────────
EVENT_POLL_INTERVAL_MS=5000

# ── Webhooks ──────────────────────────────────────────────────────────────────
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_BASE_MS=1000
